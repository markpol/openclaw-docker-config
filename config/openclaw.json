{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "auth": {
      "allowTailscale": true
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "controlUi": {
      "allowInsecureAuth": false,
      "allowedOrigins": [
        "https://openclaw-prod.${TAILSCALE_DOMAIN}"
      ]
    }
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "streaming": {
        "mode": "partial"
      }
    }
  },

  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      },
      "vercel-ai-gateway": {
        "enabled": true
      }
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "vercel-ai-gateway/xai/grok-4-fast-reasoning"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 2,
      "subagents": {
        "maxConcurrent": 4
      }
    }
  },

  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },

  "messages": {
    "ackReactionScope": "group-mentions"
  },

  "logging": {
    "level": "info",
    "consoleLevel": "info",
    "redactSensitive": "tools"
  },

  "auth": {
    "profiles": {
      "vercel-ai-gateway:default": {
        "provider": "vercel-ai-gateway",
        "mode": "api_key"
      }
    }
  },

  "mcp": {
    "servers": {
      "github": {
        "command": "docker",
        "args": [
          "run",
          "-i",
          "--rm",
          "-e",
          "GITHUB_PERSONAL_ACCESS_TOKEN",
          "-e",
          "GITHUB_DYNAMIC_TOOLSETS",  
          "-e",
          "GITHUB_INSIDERS",
          "ghcr.io/github/github-mcp-server"
        ],
        "env": {
          "GITHUB_PERSONAL_ACCESS_TOKEN": "${GH_TOKEN}",
          "GITHUB_DYNAMIC_TOOLSETS": "1",
          "GITHUB_INSIDERS": "true"
        }
      }
    }
  }
}
